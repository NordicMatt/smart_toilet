/*
 * Application Memfault heartbeat metrics (uploaded directly to Memfault over
 * HTTPS). Used to diagnose wake-word detection remotely, off wall USB with no
 * serial attached. Reported once per heartbeat interval
 * (CONFIG_MEMFAULT_METRICS_HEARTBEAT_INTERVAL_SECS).
 *
 * dBFS values are stored as deci-dBFS (dB * 10) so they fit a signed integer:
 * e.g. -38.5 dBFS is stored as -385.
 */

/* Loudest peak level seen during the interval (deci-dBFS). High = mic is
 * receiving signal; pinned low = weak/dead mic. */
MEMFAULT_METRICS_KEY_DEFINE(audio_peak_dbfs, kMemfaultMetricType_Signed)

/* Quietest RMS (noise floor) during the interval (deci-dBFS). */
MEMFAULT_METRICS_KEY_DEFINE(audio_noise_floor_dbfs, kMemfaultMetricType_Signed)

/* Clipped samples accumulated during the interval (too loud / gain too high). */
MEMFAULT_METRICS_KEY_DEFINE(audio_clip_count, kMemfaultMetricType_Unsigned)

/* Highest wake-word probability reached during the interval, as a percent
 * (0-100). If this stays well below the detection bar, the model isn't
 * recognising the word (or the mic signal is too weak). */
MEMFAULT_METRICS_KEY_DEFINE(ww_prob_max_pct, kMemfaultMetricType_Unsigned)

/* Confirmed wake-word detections during the interval. */
MEMFAULT_METRICS_KEY_DEFINE(ww_detections, kMemfaultMetricType_Unsigned)

/* Wake-word confidence summary, so the observability distribution is visible in
 * the heartbeat dashboard (not only in the edgeai_observability CDR):
 *   ww_prob_mean_pct - mean P(wakeword) over the interval, percent (0-100)
 *   ww_inferences    - number of model inferences run in the interval
 * Read alongside ww_prob_max_pct (peak) and ww_detections (fires). */
MEMFAULT_METRICS_KEY_DEFINE(ww_prob_mean_pct, kMemfaultMetricType_Unsigned)
MEMFAULT_METRICS_KEY_DEFINE(ww_inferences, kMemfaultMetricType_Unsigned)

/* Flushes during the heartbeat interval (a per-interval event counter, like
 * ww_detections). Incremented once per completed flush and reset by Memfault
 * each heartbeat, so the timeseries reads flushes-per-interval; sum it over a
 * day for flushes/day. NOT the lifetime total — the device keeps that in NVS
 * for its own record but no longer reports it. */
MEMFAULT_METRICS_KEY_DEFINE(flush_count, kMemfaultMetricType_Unsigned)

/* Motor runs that hit the safety timeout without ever seeing the magnet leave
 * home (possible jam/stuck sensor). Not persisted - a spike in this per
 * interval is the signal, not the lifetime total. */
MEMFAULT_METRICS_KEY_DEFINE(flush_jam_count, kMemfaultMetricType_Unsigned)

/* Failsafe-button presses during the interval (debounced edges from the P1.08
 * switch ISR). Differentiates how flushes are triggered: button vs. voice ~=
 * flush_count - button_press_count (approximately - a press during an
 * in-progress flush counts here but produces no extra flush). Per-interval
 * event counter like flush_count. */
MEMFAULT_METRICS_KEY_DEFINE(button_press_count, kMemfaultMetricType_Unsigned)

/* Tier-0 forced Wi-Fi reconnects during the interval (uploads stalled while
 * nominally connected -> stall monitor submitted a re-associate). A burst in
 * one interval marks a network outage window (e.g. overnight Nest maintenance)
 * and gives context to any upload-watchdog reboot that follows. */
MEMFAULT_METRICS_KEY_DEFINE(wifi_reconnect_count, kMemfaultMetricType_Unsigned)

/* nRF70 Wi-Fi driver data-heap health, sampled at heartbeat time. The driver
 * allocates every RX/TX packet buffer from this dedicated pool with K_FOREVER:
 * if it ever runs dry the Wi-Fi bottom-half blocks forever and connectivity is
 * dead until the stall-monitor reboot (2026-07-13 wedge). free trending toward
 * zero, or max_used approaching CONFIG_NRF_WIFI_DATA_HEAP_SIZE, is the early
 * warning of a leak or an undersized pool. */
MEMFAULT_METRICS_KEY_DEFINE(wifi_heap_free_bytes, kMemfaultMetricType_Unsigned)
MEMFAULT_METRICS_KEY_DEFINE(wifi_heap_max_used_bytes, kMemfaultMetricType_Unsigned)
