#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	chosen {
		ncs,control-output-uart = &uart30;
	};

	/* Smart toilet flush motor drive on P1.06: HIGH turns on the MOSFET
	 * that runs the motor. P1.06 is a plain GPIO routed directly to
	 * headers P1/P17 (no board-controller mux). NOTE: the P2.00-P2.05
	 * pins are NOT usable as header GPIO by default - the board
	 * controller routes them to the onboard QSPI flash, so a wire on the
	 * P2.00 header pin sees nothing.
	 */
	flush_actuator: flush-actuator {
		compatible = "smart-toilet,flush-actuator";
		gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
	};

	/* Hall effect sensor on P1.07: powered from 5V, the sensor idles HIGH
	 * (~3.6 V) and pulls the line LOW when the shaft magnet reaches it
	 * (active low - verified with a meter: present ~0 V, absent ~3.6 V).
	 * Internal pull-up is enabled in software.
	 */
	hall_sensor: hall-sensor {
		compatible = "smart-toilet,hall-sensor";
		gpios = <&gpio1 7 GPIO_ACTIVE_LOW>;
	};

	/* Failsafe flush switch on P1.08: one side wired to GND, so closing
	 * the switch pulls the line low (active low) against the internal
	 * pull-up. Triggers a flush without the wake word.
	 */
	flush_button: flush-button {
		compatible = "smart-toilet,flush-button";
		gpios = <&gpio1 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	};
};

&uart30 {
	status = "okay";
};

&pinctrl {
	pdm20_default_alt: pdm20_default_alt {
		group1 {
			psels = <NRF_PSEL(PDM_CLK, 1, 4)>,
				<NRF_PSEL(PDM_DIN, 1, 5)>;
		};
	};
};

dmic_dev: &pdm20 {
	status = "okay";
	pinctrl-0 = <&pdm20_default_alt>;
	pinctrl-names = "default";
	clock-source = "PCLK32M";
};

&axon {
	status = "okay";
};
