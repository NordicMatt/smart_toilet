menu "Wakeword and Keyword Spotting application"

choice APP_MODE
	prompt "Application mode"
	default APP_MODE_WW_GATED_KWS

config APP_MODE_WW_GATED_KWS
	bool "Wakeword-gated keyword spotting mode"
	help
	  Run keyword spotting model only after wakeword was detected. After configurable duration
	  without any keyword spotted switch back to wakeword detection.

config APP_MODE_WW_ONLY
	bool "Wakeword detection only mode"
	help
	  Run wakeword detection continuously without switching to keyword spotting.

config APP_MODE_KWS_ONLY
	bool "Keyword spotting only mode"
	help
	  Run keyword spotting continuously without the need to detect wakeword first.

endchoice

config WW_PROBABILITY_THRESHOLD
	int "Wakeword probability threshold"
	range 0 1000
	default 990
	help
	   Probability threshold for wakeword detection model. The value is expressed in units of
	   1/1000.

config WW_HISTORY_SIZE
	int "Size of wakeword predictions history"
	range 1 32
	default 20
	help
	  Size of history of previous results from wakeword detection model. Each entry corresponds
	  to 30 milliseconds of past audio.

config WW_COUNT_THRESHOLD
	int "Threshold for wakeword detection from predictions history"
	range 1 WW_HISTORY_SIZE
	default 15
	help
	  Number of predictions above threshold in predictions history required to confirm wakeword
	  detection.

config APP_PDM_GAIN_DB
	int "PDM microphone digital gain (dB)"
	range -20 20
	default 12
	help
	  Digital gain applied in the PDM peripheral on top of the 0 dB hardware
	  default. Raise it if speech at normal use distance peaks below about
	  -20 dBFS; lower it if APP_AUDIO_STATS reports clipped samples.

config APP_AUDIO_STATS
	bool "Log audio level and wake-word tuning statistics"
	help
	  Once per second, log the microphone peak/RMS level in dBFS with a
	  clipped-sample count, and the peak wake-word probability and vote
	  count. Use this to tune APP_PDM_GAIN_DB and the WW_* thresholds.

config APP_AUDIO_HPF
	bool "High-pass filter the mic audio"
	help
	  Apply a 2nd-order Butterworth high-pass at 120 Hz to each audio
	  block before detection, stripping rumble and handling noise below
	  the speech band.

config APP_AGC
	bool "Automatic gain control on the mic audio"
	help
	  Track the speech peak level and apply a smoothed software gain that
	  pulls it toward APP_AGC_TARGET_DBFS, compensating for speaker
	  distance on top of the fixed APP_PDM_GAIN_DB hardware gain. Cannot
	  undo saturation that happens in the PDM peripheral itself.

config APP_AGC_TARGET_DBFS
	int "AGC target peak level (dBFS)"
	depends on APP_AGC
	range -30 -6
	default -20
	help
	  Peak level the AGC pulls speech toward. The wake-word model is most
	  reliable with speech peaks in the -25 to -15 dBFS range.

config APP_AUDIO_PROC
	bool
	default y if APP_AUDIO_HPF || APP_AGC

config APP_AUDIO_SNAP
	bool "Audio snapshot recording over the control UART"
	help
	  On receiving the trigger byte 'S' on the control UART (VCOM0),
	  record APP_AUDIO_SNAP_SECONDS of the processed mic audio to RAM,
	  then dump it back over the same UART as an "AUDIO_SNAP <bytes>"
	  header followed by raw 16-bit little-endian PCM at 16 kHz. Save it
	  as a .wav with: tools/uart_monitor.py snap --port <VCOM0>.

config APP_AUDIO_SNAP_SECONDS
	int "Audio snapshot length (seconds)"
	depends on APP_AUDIO_SNAP
	range 1 12
	default 10
	help
	  Length of the recorded snapshot. RAM cost is 32 KB per second.

config KWS_PERIOD_MS
	int "Length of keyword spotting window in wakeword-gated mode"
	default 3000

config KWS_EMA_ALPHA
	int "Exponential moving average coefficient for class probability"
	range 0 1000
	default 120
	help
	  Coefficient for new entries in exponential moving average calculation for average class
	  probability. The value is expressed in units of 1/1000.

endmenu

source "Kconfig.zephyr"
